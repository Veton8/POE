; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Path of Evil"
config/description="Pixel-art top-down dungeon shooter (Soul Knight x Archero)"
run/main_scene="res://scenes/hub/HubRoom.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Events="*res://autoloads/Events.gd"
Joystick="*res://autoloads/Joystick.gd"
BulletPool="*res://autoloads/BulletPool.gd"
VFX="*res://autoloads/VFX.gd"
Audio="*res://autoloads/Audio.gd"
DungeonManager="*res://autoloads/DungeonManager.gd"
GameState="*res://autoloads/GameState.gd"
UpgradeRegistry="*res://scenes/upgrades/UpgradeRegistry.gd"
UpgradeManager="*res://scenes/upgrades/UpgradeManager.gd"
MarkRegistry="*res://autoloads/MarkRegistry.gd"
AutocastModifierRegistry="*res://autoloads/AutocastModifierRegistry.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

