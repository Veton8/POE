[input_devices]

pointing/emulate_touch_from_mouse=true
pointing/emulate_mouse_from_touch=false

[layer_names]

2d_physics/layer_1="world"
2d_physics/layer_2="player"
2d_physics/layer_3="enemies"
2d_physics/layer_4="player_hurtbox"
2d_physics/layer_5="enemy_hurtbox"
2d_physics/layer_6="player_bullet"
2d_physics/layer_7="enemy_bullet"
2d_physics/layer_8="pickups"

[physics]

2d/default_gravity=0.0

[rendering]

textures/canvas_textures/default_texture_filter=0
textures/vram_compression/import_etc2_astc=true
renderer/rendering_method="mobile"
environment/defaults/default_clear_color=Color(0.06, 0.05, 0.09, 1)
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
